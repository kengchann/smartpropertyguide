---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import agent from "../data/agent.json";

const projectsCollection = await getCollection("projects");
const projectOptions = projectsCollection.map((p) => p.data.name);
---

<Layout
  title="Contact"
  description="Get in touch with Carolyn Mendoza about a featured development, financing options, or a general real estate question."
>
  <section class="mx-auto max-w-5xl px-4 py-12 sm:px-6 sm:py-16">
    <p class="text-sm font-semibold uppercase tracking-wide text-terracotta-500">Contact</p>
    <h1 class="mt-2 font-display text-3xl font-bold text-primary-700 sm:text-4xl">Get in Touch</h1>
    <p class="mt-4 max-w-2xl text-sm text-ink/70 sm:text-base">
      Whether you're buying, exploring options, or have a general question — send a message
      below, or reach out directly on Messenger or WhatsApp for the fastest response.
    </p>

    <div class="mt-10 grid grid-cols-1 gap-10 lg:grid-cols-3">
      <!-- Direct contact cards -->
      <div class="order-2 flex flex-col gap-4 lg:order-1">
        <a
          href={agent.whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 rounded-2xl border border-primary-100 bg-white p-5 shadow-sm transition-shadow hover:shadow-md"
        >
          <div>
            <p class="font-display font-bold text-primary-700">Chat on WhatsApp</p>
            <p class="mt-1 text-sm text-ink/60">{agent.phoneDisplay}</p>
          </div>
        </a>
        <a
          href={agent.messengerUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 rounded-2xl border border-primary-100 bg-white p-5 shadow-sm transition-shadow hover:shadow-md"
        >
          <div>
            <p class="font-display font-bold text-primary-700">Message on Messenger</p>
            <p class="mt-1 text-sm text-ink/60">Usually replies within the day</p>
          </div>
        </a>
        <a
          href={`mailto:${agent.email}`}
          class="flex items-center gap-4 rounded-2xl border border-primary-100 bg-white p-5 shadow-sm transition-shadow hover:shadow-md"
        >
          <div>
            <p class="font-display font-bold text-primary-700">Email</p>
            <p class="mt-1 text-sm text-ink/60">{agent.email}</p>
          </div>
        </a>
        <a
          href={`tel:${agent.phoneIntl}`}
          class="flex items-center gap-4 rounded-2xl border border-primary-100 bg-white p-5 shadow-sm transition-shadow hover:shadow-md"
        >
          <div>
            <p class="font-display font-bold text-primary-700">Call / Text</p>
            <p class="mt-1 text-sm text-ink/60">{agent.phoneDisplay}</p>
          </div>
        </a>
      </div>

      <!-- Inquiry form -->
      <div class="order-1 rounded-2xl border border-primary-100 bg-white p-6 shadow-sm sm:p-8 lg:order-2 lg:col-span-2">
        <h2 class="font-display text-xl font-bold text-primary-700">Send an Inquiry</h2>

        <form
          name="contact-inquiry"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/contact/thank-you"
          class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2"
        >
          <input type="hidden" name="form-name" value="contact-inquiry" />
          <p class="hidden">
            <label>
              Don't fill this out if you're human: <input name="bot-field" />
            </label>
          </p>

          <div class="sm:col-span-1">
            <label for="name" class="text-sm font-semibold text-primary-700">Full Name</label>
            <input
              id="name"
              name="name"
              type="text"
              required
              class="mt-1.5 w-full rounded-lg border border-primary-200 px-3 py-2.5 text-sm text-ink focus:border-primary-500 focus:outline-none"
            />
          </div>

          <div class="sm:col-span-1">
            <label for="email" class="text-sm font-semibold text-primary-700">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              class="mt-1.5 w-full rounded-lg border border-primary-200 px-3 py-2.5 text-sm text-ink focus:border-primary-500 focus:outline-none"
            />
          </div>

          <div class="sm:col-span-1">
            <label for="phone" class="text-sm font-semibold text-primary-700">Phone Number</label>
            <input
              id="phone"
              name="phone"
              type="tel"
              class="mt-1.5 w-full rounded-lg border border-primary-200 px-3 py-2.5 text-sm text-ink focus:border-primary-500 focus:outline-none"
            />
          </div>

          <div class="sm:col-span-1">
            <label for="inquiryType" class="text-sm font-semibold text-primary-700">I am a</label>
            <select
              id="inquiryType"
              name="inquiryType"
              class="mt-1.5 w-full rounded-lg border border-primary-200 bg-white px-3 py-2.5 text-sm text-ink focus:border-primary-500 focus:outline-none"
            >
              <option value="Buyer">Buyer</option>
              <option value="Seller">Seller</option>
              <option value="Just Exploring">Just Exploring</option>
            </select>
          </div>

          <div class="sm:col-span-2">
            <label for="project" class="text-sm font-semibold text-primary-700">Project of Interest</label>
            <select
              id="project"
              name="project"
              class="mt-1.5 w-full rounded-lg border border-primary-200 bg-white px-3 py-2.5 text-sm text-ink focus:border-primary-500 focus:outline-none"
            >
              <option value="General Inquiry">General Inquiry / Not Sure Yet</option>
              {projectOptions.map((name) => <option value={name}>{name}</option>)}
            </select>
          </div>

          <div class="sm:col-span-2">
            <label for="message" class="text-sm font-semibold text-primary-700">Message</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              class="mt-1.5 w-full rounded-lg border border-primary-200 px-3 py-2.5 text-sm text-ink focus:border-primary-500 focus:outline-none"
            ></textarea>
          </div>

          <div class="sm:col-span-2">
            <button
              type="submit"
              class="w-full rounded-sm bg-primary-700 px-7 py-3.5 text-xs font-semibold uppercase tracking-wider text-cream transition-colors hover:bg-primary-600 sm:w-auto"
            >
              Send Inquiry
            </button>
          </div>
        </form>

        <p class="mt-5 rounded-lg border border-dashed border-primary-300 bg-primary-50 px-4 py-2 text-xs text-primary-600">
          Note for development: this form is wired for Netlify Forms and will only actually
          submit once the site is deployed to Netlify — that's expected while testing locally.
        </p>
      </div>
    </div>
  </section>
</Layout>
