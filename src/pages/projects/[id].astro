---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import agent from "../../data/agent.json";

export async function getStaticPaths() {
  const collection = await getCollection("projects");
  return collection.map((entry) => {
    return {
      params: { id: entry.id },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const project = { id: entry.id, ...entry.data };
const { Content } = await render(entry);

const statusStyles: Record<string, string> = {
  Selling: "bg-primary-100 text-primary-700",
  "Limited Units Left": "bg-accent-100 text-accent-600",
  "Sold Out": "bg-ink/10 text-ink/60",
};

const inquiryText = `Hi Carolyn, I'm interested in ${project.name}. Can you share more details?`;
const whatsappInquiry = `${agent.whatsappUrl}?text=${encodeURIComponent(inquiryText)}`;

const allProjects = await getCollection("projects");
const related = allProjects
  .filter((p) => p.id !== project.id && p.data.type === project.type)
  .slice(0, 3)
  .map((p) => ({ id: p.id, ...p.data }));
const soldOut = project.status === "Sold Out";
---

<Layout title={project.name} description={project.brandTag}>
  <section class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
    <nav class="text-xs text-ink/50">
      <a href="/" class="hover:text-primary-700">Home</a>
      <span class="mx-1.5">/</span>
      <a href="/projects" class="hover:text-primary-700">Featured Developments</a>
      <span class="mx-1.5">/</span>
      <span class="text-ink/70">{project.name}</span>
    </nav>

    <div class="relative mt-4 overflow-hidden rounded-2xl bg-primary-900">
      <img src={project.image} alt={`${project.name} — sample placeholder image`} class="aspect-[16/9] w-full object-cover sm:aspect-[21/9]" />
      <span class:list={["absolute right-4 top-4 rounded-full px-3 py-1 text-xs font-semibold", statusStyles[project.status] ?? "bg-white/90 text-ink"]}>
        {project.status}
      </span>
    </div>

    <div class="mt-8 grid grid-cols-1 gap-10 lg:grid-cols-3">
      <div class="lg:col-span-2">
        <p class="text-xs font-semibold uppercase tracking-wide text-terracotta-500">{project.brandTag}</p>
        <h1 class="mt-1 font-display text-2xl font-bold text-primary-700 sm:text-3xl">{project.name}</h1>
        <p class="mt-1 text-sm text-ink/60">{project.location}</p>

        <div class="prose prose-sm mt-5 max-w-none text-ink/80 sm:text-base">
          <Content />
        </div>

        <div class="mt-8 grid grid-cols-2 gap-4 rounded-xl border border-primary-100 bg-white p-5 sm:grid-cols-4">
          <div>
            <p class="text-xs uppercase tracking-wide text-ink/50">Price</p>
            <p class="mt-1 text-sm font-semibold text-primary-700">{project.priceLabel}</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wide text-ink/50">Layout</p>
            <p class="mt-1 text-sm font-semibold text-primary-700">{project.bedrooms}</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wide text-ink/50">Area</p>
            <p class="mt-1 text-sm font-semibold text-primary-700">{project.areaLabel}</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wide text-ink/50">Type</p>
            <p class="mt-1 text-sm font-semibold text-primary-700">{project.type}</p>
          </div>
        </div>

        <div class="mt-6">
          <p class="text-sm font-semibold text-primary-700">Payment Terms</p>
          <div class="mt-2 flex flex-wrap gap-2">
            {project.paymentTerms.map((term) => (
              <span class="rounded-full bg-primary-50 px-3 py-1.5 text-xs font-medium text-primary-600">{term}</span>
            ))}
          </div>
        </div>
      </div>

      <aside class="h-fit rounded-2xl border border-primary-100 bg-white p-6 shadow-sm">
        {soldOut ? (
          <div>
            <p class="font-display text-lg font-bold text-primary-700">This Project is Sold Out</p>
            <p class="mt-2 text-sm text-ink/60">
              Ask Carolyn about similar available developments in the same area.
            </p>
          </div>
        ) : (
          <div>
            <p class="font-display text-lg font-bold text-primary-700">Interested in {project.name}?</p>
            <p class="mt-2 text-sm text-ink/60">Message Carolyn directly for the latest pricing, unit availability, and site visit schedules.</p>
          </div>
        )}
        <div class="mt-5 flex flex-col gap-3">
          <a
            href={whatsappInquiry}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-full bg-primary-700 px-5 py-3 text-sm font-semibold text-cream transition-colors hover:bg-primary-600"
          >
            Chat on WhatsApp
          </a>
          <a
            href={agent.messengerUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-full border border-primary-700 px-5 py-3 text-sm font-semibold text-primary-700 transition-colors hover:bg-primary-700 hover:text-cream"
          >
            Message on Messenger
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center rounded-full border border-primary-200 px-5 py-3 text-sm font-semibold text-primary-700 transition-colors hover:bg-primary-50"
          >
            Send an Inquiry Form
          </a>
        </div>
      </aside>
    </div>
  </section>

  {related.length > 0 && (
    <section class="mx-auto max-w-5xl px-4 pb-16 sm:px-6">
      <h2 class="font-display text-xl font-bold text-primary-700 sm:text-2xl">You Might Also Like</h2>
      <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {related.map((p) => <ProjectCard project={p} />)}
      </div>
    </section>
  )}
</Layout>
