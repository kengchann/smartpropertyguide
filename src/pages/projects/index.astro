---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ProjectCard from "../../components/ProjectCard.astro";

const collection = await getCollection("projects");
const allProjects = collection.map((p) => ({ id: p.id, ...p.data }));

const filters = ["All", "House & Lot", "Condominium"];
---

<Layout
  title="Featured Developments"
  description="Explore pre-selling house-and-lot and condominium developments across Vista Land brands, represented by Carolyn Mendoza."
>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">
    <p class="text-sm font-semibold uppercase tracking-wide text-terracotta-500">Featured Developments</p>
    <h1 class="mt-2 font-display text-3xl font-bold text-primary-700 sm:text-4xl">
      Pre-Selling Developments Across Vista Land Brands
    </h1>
    <p class="mt-4 max-w-2xl text-sm text-ink/70 sm:text-base">
      These are current pre-selling developments Carolyn represents as a sales partner under
      Vista Land International Premier — house-and-lot communities and condominium/high-rise
      projects across CrownAsia, Vista Residences, and other Vista Land brands. This is not a
      resale listings page.
    </p>
    <p class="mt-3 max-w-2xl rounded-lg border border-dashed border-primary-300 bg-primary-50 px-4 py-2 text-xs text-primary-600">
      Every project below is a fictional sample used for layout purposes — see NOTES.md in the project files for what to replace with real developments.
    </p>

    <div class="mt-8 flex flex-wrap gap-2" id="filter-tabs">
      {filters.map((f, i) => (
        <button
          type="button"
          data-filter={f}
          class:list={[
            "filter-btn rounded-full border px-4 py-2 text-sm font-semibold transition-colors",
            i === 0 ? "border-primary-700 bg-primary-700 text-cream" : "border-primary-200 text-primary-700 hover:bg-primary-50",
          ]}
        >
          {f}
        </button>
      ))}
    </div>

    <div id="project-grid" class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {allProjects.map((project) => (
        <div data-type={project.type} class="project-item">
          <ProjectCard project={project} />
        </div>
      ))}
    </div>
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const items = document.querySelectorAll<HTMLElement>(".project-item");

  const activeClasses = ["border-primary-700", "bg-primary-700", "text-cream"];
  const inactiveClasses = ["border-primary-200", "text-primary-700"];

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;

      buttons.forEach((b) => {
        b.classList.remove(...activeClasses);
        b.classList.add(...inactiveClasses);
      });
      btn.classList.remove(...inactiveClasses);
      btn.classList.add(...activeClasses);

      items.forEach((item) => {
        const matches = filter === "All" || item.dataset.type === filter;
        item.classList.toggle("hidden", !matches);
      });
    });
  });
</script>
