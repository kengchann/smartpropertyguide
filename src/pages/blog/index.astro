---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const collection = await getCollection("blog", ({ data }) => !data.draft);
const posts = collection
  .map((p) => ({ id: p.id, ...p.data }))
  .sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());

const dateFormatter = new Intl.DateTimeFormat("en-PH", { year: "numeric", month: "long", day: "numeric" });
---

<Layout
  title="Blog"
  description="Local real estate market insights, buying guides, and tips from Carolyn Mendoza."
>
  <section class="mx-auto max-w-5xl px-4 py-12 sm:px-6 sm:py-16">
    <p class="text-sm font-semibold uppercase tracking-wide text-terracotta-500">Blog</p>
    <h1 class="mt-2 font-display text-3xl font-bold text-primary-700 sm:text-4xl">Local Market Insights</h1>
    <p class="mt-4 max-w-2xl text-sm text-ink/70 sm:text-base">
      Practical guides on buying, financing, and navigating pre-selling developments in the
      Philippines.
    </p>
    <p class="mt-3 max-w-2xl rounded-lg border border-dashed border-primary-300 bg-primary-50 px-4 py-2 text-xs text-primary-600">
      The posts below are sample content written for this demo site — see NOTES.md.
    </p>

    <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="group flex flex-col overflow-hidden rounded-2xl border border-primary-100 bg-white shadow-sm transition-shadow hover:shadow-md">
          <div class="aspect-[16/9] w-full overflow-hidden bg-primary-900">
            <img
              src={post.image}
              alt={`${post.title} — sample placeholder image`}
              class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
              loading="lazy"
            />
          </div>
          <div class="flex flex-1 flex-col p-5">
            <p class="text-xs text-ink/50">{dateFormatter.format(post.pubDate)} · {post.author}</p>
            <h2 class="mt-2 font-display text-lg font-bold text-primary-700">{post.title}</h2>
            <p class="mt-2 text-sm text-ink/70">{post.excerpt}</p>
            <span class="mt-4 text-sm font-semibold text-primary-700">Read More &rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
