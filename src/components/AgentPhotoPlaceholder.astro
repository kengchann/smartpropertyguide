---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div class:list={["relative mx-auto flex aspect-square w-full items-center justify-center rounded-3xl border-2 border-dashed border-primary-300 bg-primary-50", className]}>
  <div class="p-6 text-center">
    <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-20 w-20 text-primary-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
    </svg>
    <p class="mt-3 text-sm font-semibold text-primary-600">Agent photo placeholder</p>
    <p class="mt-1 text-xs text-primary-500">Real photo of Carolyn Mendoza to be added</p>
  </div>
</div>
