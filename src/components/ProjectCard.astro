---
interface Project {
  id: string;
  name: string;
  brandTag: string;
  type: string;
  location: string;
  priceLabel: string;
  bedrooms: string;
  areaLabel: string;
  paymentTerms: string[];
  status: string;
  image: string;
  isSample?: boolean;
}

interface Props {
  project: Project;
}

const { project } = Astro.props;

const statusStyles: Record<string, string> = {
  Selling: "bg-primary-100 text-primary-700",
  "Limited Units Left": "bg-accent-100 text-accent-600",
  "Sold Out": "bg-ink/10 text-ink/60",
};
---

<article class="group flex flex-col overflow-hidden rounded-lg bg-white shadow-md transition-shadow duration-300 hover:shadow-xl">
  <div class="relative aspect-[4/3] w-full overflow-hidden bg-primary-900">
    <img
      src={project.image}
      alt={project.name}
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
    <span class:list={["absolute right-3 top-3 rounded-sm px-3 py-1 text-[11px] font-semibold uppercase tracking-wider", statusStyles[project.status] ?? "bg-white/90 text-ink"]}>
      {project.status}
    </span>
    <span class="absolute bottom-3 left-3 rounded-sm bg-black/50 px-2 py-0.5 text-[10px] uppercase tracking-wider text-white/80">
      Sample Photo
    </span>
  </div>

  <div class="flex flex-1 flex-col p-6">
    <p class="text-[11px] font-semibold uppercase tracking-[0.15em] text-accent-600">{project.brandTag}</p>
    <h3 class="mt-2 font-display text-2xl font-bold text-primary-700">{project.name}</h3>
    <p class="mt-1 text-sm italic text-ink/60">{project.location}</p>

    <div class="my-4 h-px bg-primary-100"></div>

    <dl class="space-y-1.5 text-sm text-ink/80">
      <div class="flex justify-between"><dt>Price</dt><dd class="font-semibold text-primary-700">{project.priceLabel}</dd></div>
      <div class="flex justify-between"><dt>Layout</dt><dd>{project.bedrooms}</dd></div>
      <div class="flex justify-between"><dt>Area</dt><dd>{project.areaLabel}</dd></div>
    </dl>

    <div class="mt-4 flex flex-wrap gap-1.5">
      {project.paymentTerms.map((term) => (
        <span class="rounded-sm bg-primary-50 px-2.5 py-1 text-xs font-medium text-primary-600">{term}</span>
      ))}
    </div>

    <a
      href={`/projects/${project.id}`}
      class="mt-6 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-primary-700 transition-colors hover:text-accent-600"
    >
      View Details <span aria-hidden="true">&rarr;</span>
    </a>
  </div>
</article>
