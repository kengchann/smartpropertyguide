---
import agent from "../data/agent.json";

const year = new Date().getFullYear();
---

<footer class="border-t border-primary-100 bg-primary-900 text-cream">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 sm:px-6 md:grid-cols-3">
    <div>
      <p class="font-display text-lg font-bold">{agent.pageName}</p>
      <p class="mt-2 text-sm text-primary-100">{agent.name}</p>
      <p class="text-sm text-primary-300">{agent.title}, {agent.company}</p>
    </div>

    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-accent-400">Get in Touch</p>
      <ul class="mt-3 space-y-2 text-sm text-primary-100">
        <li><a href={`tel:${agent.phoneIntl}`} class="hover:text-cream">{agent.phoneDisplay}</a></li>
        <li><a href={`mailto:${agent.email}`} class="hover:text-cream">{agent.email}</a></li>
        <li><a href={agent.whatsappUrl} target="_blank" rel="noopener noreferrer" class="hover:text-cream">WhatsApp</a></li>
        <li><a href={agent.messengerUrl} target="_blank" rel="noopener noreferrer" class="hover:text-cream">Messenger</a></li>
        <li><a href={agent.instagramUrl} target="_blank" rel="noopener noreferrer" class="hover:text-cream">Instagram {agent.instagramHandle}</a></li>
      </ul>
    </div>

    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-accent-400">Quick Links</p>
      <ul class="mt-3 space-y-2 text-sm text-primary-100">
        <li><a href="/projects" class="hover:text-cream">Featured Developments</a></li>
        <li><a href="/about" class="hover:text-cream">About Carolyn</a></li>
        <li><a href="/blog" class="hover:text-cream">Blog</a></li>
        <li><a href="/contact" class="hover:text-cream">Contact / Inquire</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-primary-700 px-4 py-6 text-center text-xs text-primary-300 sm:px-6">
    <p>
      {agent.name} markets pre-selling developments under Vista Land International Premier
      (CrownAsia, Vista Residences, and other Vista Land brands). Project names, photos, and
      pricing shown as "sample" on this site are placeholders and do not represent actual
      developer listings.
    </p>
    <p class="mt-2">&copy; {year} {agent.pageName}. All rights reserved.</p>
  </div>
</footer>
