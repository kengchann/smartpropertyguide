---
import agent from "../data/agent.json";

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Featured Developments" },
  { href: "/about", label: "About" },
  { href: "/blog", label: "Blog" },
  { href: "/contact", label: "Contact" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-primary-100 bg-cream/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6">
    <a href="/" class="flex flex-col leading-tight">
      <span class="font-display text-lg font-bold text-primary-700 sm:text-xl">{agent.pageName}</span>
      <span class="text-xs text-primary-500">with {agent.name}</span>
    </a>

    <nav class="hidden items-center gap-6 md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "text-sm font-medium transition-colors hover:text-primary-700",
            currentPath === link.href ? "text-primary-700" : "text-ink/70",
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href={agent.messengerUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full bg-primary-700 px-4 py-2 text-sm font-semibold text-cream shadow-sm transition-colors hover:bg-primary-600"
      >
        Message on Messenger
      </a>
    </nav>

    <button
      id="menu-toggle"
      type="button"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      class="flex h-10 w-10 items-center justify-center rounded-md border border-primary-100 text-primary-700 md:hidden"
    >
      <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <nav id="mobile-menu" class="hidden flex-col gap-1 border-t border-primary-100 bg-cream px-4 pb-4 md:hidden">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class:list={[
          "rounded-md px-3 py-2 text-base font-medium",
          currentPath === link.href ? "bg-primary-50 text-primary-700" : "text-ink/80 hover:bg-primary-50",
        ]}
      >
        {link.label}
      </a>
    ))}
    <a
      href={agent.messengerUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-2 rounded-full bg-primary-700 px-4 py-3 text-center text-sm font-semibold text-cream"
    >
      Message on Messenger
    </a>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    menu?.classList.toggle("flex", isOpen);
    toggle.setAttribute("aria-expanded", String(isOpen));
    iconOpen?.classList.toggle("hidden", isOpen);
    iconClose?.classList.toggle("hidden", !isOpen);
  });
</script>
